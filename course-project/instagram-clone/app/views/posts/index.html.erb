<h1 class="title">Все посты</h1>

<% @posts.each do |post| %>
  <article class="card">
    <p class="meta">
      <strong><%= post.user.username %></strong>
      - <%= l(post.created_at, format: :short) %>
    </p>
    <p><%= post.caption %></p>
    <% if post.image.attached? %>
      <p><%= image_tag post.image, class: "post-image" %></p>
    <% end %>
    <div class="reaction">
      <span class="badge">Лайки: <%= post.likes_count %></span>
      <span class="badge">Дизлайки: <%= post.dislikes_count %></span>
    </div>
    <div class="actions">
      <%= link_to "Открыть", post_path(post), class: "btn btn-secondary" %>
      <% if post.user == current_user %>
        <%= link_to "Редактировать", edit_post_path(post), class: "btn btn-ghost" %>
        <%= button_to "Удалить", post_path(post), method: :delete, class: "btn btn-danger", form_class: "inline-form" %>
      <% end %>
    </div>
  </article>
<% end %>
