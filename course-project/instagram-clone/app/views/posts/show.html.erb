<h1>Пост</h1>

<p><strong>Автор:</strong> <%= link_to @post.user.username, user_path(@post.user) %></p>
<p><strong>Подпись:</strong> <%= @post.caption %></p>
<% if @post.user == current_user %>
  <p><%= link_to "Редактировать", edit_post_path(@post) %></p>
<% end %>

<% if @post.image.attached? %>
  <p><%= image_tag @post.image, style: "max-width: 450px;" %></p>
<% end %>

<p>
  Лайки: <%= @post.likes.count %>
  <%= button_to "Лайк / Дизлайк", post_like_path(@post), method: :post, form: { style: "display:inline;" } %>
</p>

<h2>Комментарии</h2>
<%= form_with model: [@post, @comment] do |f| %>
  <p>
    <%= f.label :body, "Текст комментария" %><br>
    <%= f.text_area :body, rows: 3 %>
  </p>
  <p><%= f.submit "Добавить комментарий" %></p>
<% end %>

<% @comments.each do |comment| %>
  <p>
    <strong><%= comment.user.username %>:</strong>
    <%= comment.body %>
    <% if comment.user == current_user %>
      <%= button_to "Удалить", post_comment_path(@post, comment), method: :delete, form: { style: "display:inline;" } %>
    <% end %>
  </p>
<% end %>
