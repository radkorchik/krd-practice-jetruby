<article class="card">
  <h1 class="title">Пост</h1>

  <p class="meta"><strong>Автор:</strong> <%= link_to @post.user.username, user_path(@post.user) %></p>
  <p><strong>Подпись:</strong> <%= @post.caption %></p>
  <% if @post.user == current_user %>
    <div class="actions"><%= link_to "Редактировать", edit_post_path(@post), class: "btn btn-ghost" %></div>
  <% end %>

  <% if @post.image.attached? %>
    <p><%= image_tag @post.image, class: "post-image" %></p>
  <% end %>

  <div class="reaction">
    <span class="badge">Лайки: <%= @post.likes_count %></span>
    <span class="badge">Дизлайки: <%= @post.dislikes_count %></span>
  </div>
  <div class="actions">
    <%= button_to "Лайк", post_like_path(@post), method: :post, class: "btn", form_class: "inline-form" %>
    <%= button_to "Дизлайк", post_dislike_path(@post), method: :post, class: "btn btn-danger", form_class: "inline-form" %>
  </div>
</article>

<section class="card">
  <h2 class="title">Комментарии</h2>
  <%= form_with model: [@post, @comment] do |f| %>
    <div class="form-row">
      <%= f.label :body, "Текст комментария" %>
      <%= f.text_area :body, rows: 3 %>
    </div>
    <div class="actions"><%= f.submit "Добавить комментарий" %></div>
  <% end %>

  <% @comments.each do |comment| %>
    <article class="card">
      <p><strong><%= comment.user.username %>:</strong> <%= comment.body %></p>
      <% if comment.user == current_user || @post.user == current_user %>
        <div class="actions">
          <%= button_to "Удалить", post_comment_path(@post, comment), method: :delete, class: "btn btn-danger", form_class: "inline-form" %>
        </div>
      <% end %>
    </article>
  <% end %>
</section>
