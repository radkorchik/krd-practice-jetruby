<%= form_with model: post do |f| %>
  <% if post.errors.any? %>
    <div>
      <h3>Ошибки:</h3>
      <ul>
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <p>
    <%= f.label :caption, "Подпись" %><br>
    <%= f.text_area :caption, rows: 4 %>
  </p>

  <p>
    <%= f.label :image, "Изображение" %><br>
    <%= f.file_field :image, accept: "image/*" %>
  </p>

  <p><%= f.submit %></p>
<% end %>
