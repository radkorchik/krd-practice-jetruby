<div class="card">
  <h2 class="title">Регистрация</h2>
  <p class="subtitle">Создайте профиль для публикации постов и работы с лентой.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="form-row">
      <%= f.label :username, "Имя пользователя" %>
      <%= f.text_field :username, autofocus: true, autocomplete: "username" %>
    </div>

    <div class="form-row">
      <%= f.label :email, "Email" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
    </div>

    <div class="form-row">
      <%= f.label :password, "Пароль" %>
      <% if @minimum_password_length %>
        <p class="meta">(Минимум символов: <%= @minimum_password_length %>)</p>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password" %>
    </div>

    <div class="form-row">
      <%= f.label :password_confirmation, "Подтверждение пароля" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
    </div>

    <div class="actions">
      <%= f.submit "Создать аккаунт" %>
    </div>
  <% end %>

  <div class="actions">
    <%= render "devise/shared/links" %>
  </div>
</div>
