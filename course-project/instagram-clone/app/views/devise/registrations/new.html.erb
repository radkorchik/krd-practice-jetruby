<h2>Регистрация</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <p><%= f.label :username, "Имя пользователя" %></p>
    <p><%= f.text_field :username, autofocus: true, autocomplete: "username" %></p>
  </div>

  <div class="field">
    <p><%= f.label :email, "Email" %></p>
    <p><%= f.email_field :email, autofocus: true, autocomplete: "email" %></p>
  </div>

  <div class="field">
    <p><%= f.label :password, "Пароль" %></p>
    <% if @minimum_password_length %>
      <p><em>(Минимум символов: <%= @minimum_password_length %>)</em></p>
    <% end %>
    <p><%= f.password_field :password, autocomplete: "new-password" %></p>
  </div>

  <div class="field">
    <p><%= f.label :password_confirmation, "Подтверждение пароля" %></p>
    <p><%= f.password_field :password_confirmation, autocomplete: "new-password" %></p>
  </div>

  <div class="actions">
    <%= f.submit "Создать аккаунт" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
