<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Instagram Clone" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Instagram Clone">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body>
    <div class="app-shell">
      <header class="app-header">
        <div class="brand">InstaMini</div>
        <nav class="nav-links">
          <% if user_signed_in? %>
            <%= link_to "Лента", feed_path, class: "nav-link" %>
            <%= link_to "Посты", posts_path, class: "nav-link" %>
            <%= link_to "Пользователи", users_path, class: "nav-link" %>
            <%= link_to "Новый пост", new_post_path, class: "nav-link nav-link--accent" %>
            <%= button_to "Выйти", destroy_user_session_path, method: :delete, class: "btn btn-ghost", form_class: "inline-form" %>
          <% else %>
            <%= link_to "Вход", new_user_session_path, class: "nav-link" %>
            <%= link_to "Регистрация", new_user_registration_path, class: "nav-link nav-link--accent" %>
          <% end %>
        </nav>
      </header>

      <main class="page-content">
        <% flash.each do |type, message| %>
          <div class="flash flash-<%= type %>"><%= message %></div>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
