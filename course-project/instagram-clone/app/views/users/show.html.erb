<h1 class="title">Профиль: <%= @user.username %></h1>

<div class="card">
  <div class="reaction">
    <span class="badge">Подписчики: <%= @user.followers.count %></span>
    <span class="badge">Подписки: <%= @user.following.count %></span>
  </div>

  <% if @user != current_user %>
    <div class="actions">
      <% if @follow %>
        <%= button_to "Отписаться", follow_path(@follow), method: :delete, class: "btn btn-danger", form_class: "inline-form" %>
      <% else %>
        <%= button_to "Подписаться", follows_path(followed_id: @user.id), method: :post, class: "btn", form_class: "inline-form" %>
      <% end %>
    </div>
  <% end %>
</div>

<h2 class="title">Посты</h2>
<% @posts.each do |post| %>
  <article class="card">
    <p><%= post.caption %></p>
    <% if post.image.attached? %>
      <p><%= image_tag post.image, class: "post-image" %></p>
    <% end %>
    <div class="reaction">
      <span class="badge">Лайки: <%= post.likes_count %></span>
      <span class="badge">Дизлайки: <%= post.dislikes_count %></span>
    </div>
    <div class="actions"><%= link_to "Открыть", post_path(post), class: "btn btn-secondary" %></div>
  </article>
<% end %>
