<%= form_with model: lab_report do |f| %>
  <% if lab_report.errors.any? %>
    <div id="error_explanation">
      <h2>Ошибки (<%= lab_report.errors.count %>):</h2>
      <ul>
        <% lab_report.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :user_id, "Студент" %><br>
    <%= f.collection_select :user_id, User.order(:last_name, :first_name), :id, :full_name, { prompt: "Выберите студента" }, required: true %>
  </div>

  <div>
    <%= f.label :title, "Заголовок" %><br>
    <%= f.text_field :title, required: true, maxlength: 250 %>
  </div>

  <div>
    <%= f.label :description, "Описание" %><br>
    <%= f.text_area :description, rows: 6, maxlength: 500 %>
  </div>

  <div>
    <%= f.label :grade, "Оценка (ECTS)" %><br>
    <%= f.select :grade, ects_grade_options %>
  </div>

  <div>
    <%= f.submit "Сохранить" %>
  </div>
<% end %>
