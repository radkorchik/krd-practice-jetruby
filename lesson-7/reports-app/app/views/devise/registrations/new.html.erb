<h1>Регистрация</h1>

<%= form_with model: resource, as: resource_name, url: registration_path(resource_name), data: { turbo: false } do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div>
    <%= f.label :first_name, "Имя" %><br>
    <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name" %>
  </div>

  <div>
    <%= f.label :last_name, "Фамилия" %><br>
    <%= f.text_field :last_name, autocomplete: "family-name" %>
  </div>

  <div>
    <%= f.label :email, "Email" %><br>
    <%= f.email_field :email, autocomplete: "email" %>
  </div>

  <div>
    <%= f.label :password, "Пароль" %><br>
    <%= f.password_field :password, autocomplete: "new-password" %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Подтверждение пароля" %><br>
    <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
  </div>

  <div style="margin-top: 12px;">
    <%= f.submit "Создать аккаунт" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>

