<% if resource.errors.any? %>
  <div id="error_explanation" style="margin-top: 12px;">
    <h2>
      <%= pluralize(resource.errors.count, "ошибка") %> запрещают сохранить форму:
    </h2>
    <ul>
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

